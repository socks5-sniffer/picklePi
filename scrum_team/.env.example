# CrewAI / LLM API Key (required)
# Supports OpenAI, Anthropic, Google, etc. via LiteLLM.
# Example: OPENAI_API_KEY, ANTHROPIC_API_KEY, GEMINI_API_KEY
OPENAI_API_KEY=your-openai-api-key-here

# Firebase project configuration (required for project-board sync)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=/path/to/serviceAccountKey.json

# Optional: Override the default LLM model
# CREWAI_LLM_MODEL=gpt-4o

# Note: Never commit actual secrets or credentials to version control.
