rules_version = '2';

// All Firestore access goes through the Flask backend (backend/app.py) using
// the Admin SDK, which bypasses these rules. The web app's Firebase config is
// public by design, so without this deny-all policy anyone could read/write
// the database directly with the client SDK, bypassing the backend's token
// verification, IDOR guard, and input sanitisation.
//
// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
