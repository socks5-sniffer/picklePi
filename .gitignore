node_modules/
build/
dist/
coverage/
.DS_Store
Thumbs.db
*.log
.env*
!.env.example

# TypeScript incremental build info
*.tsbuildinfo

# TLS/SSL certificate files (generated by vite-plugin-mkcert)
*.pem
*.crt
*.p12

# SQLite database files (generated by better-sqlite3)
*.db
*.sqlite
*.sqlite3

# Security audit and scan reports (exclude generated reports, but keep documentation)
security-report.*
audit-report.*
vulnerability-scan.*
npm-audit-report.json
eslint-security-report.json
eslint.config.security.mjs
.eslintrc.security.json
# Keep docs directory structure but not necessarily all contents
!docs/screenshots/.gitkeep

# backend — sensitive implementation files and credentials
backend/app.py
backend/bouncer.py
backend/middleware.py
backend/logger.py
backend/firebase-secret.json
backend/.env
backend/__pycache__/
backend/*.pyc

notes.md

